{
  "version": 1,
  "project": "repo-harness",
  "mode": "repo-contract-external-knowledge",
  "default_brain_path": "brain/repo-harness/*",
  "rules": [
    "repo-local contracts, hooks, scripts, checks, and evidence remain authoritative",
    "default brain stores long-lived explanations, runbooks, decisions, references, and patterns",
    "external brain sync is manual opt-in; hooks and workflow checks do not read, write, or validate external vault state"
  ],
  "entries": [
    {
      "id": "ai-workflows",
      "role": "externalized",
      "repo_path": "docs/reference-configs/ai-workflows.md",
      "asset_path": "assets/reference-configs/ai-workflows.md",
      "brain_path": "brain/repo-harness/references/ai-assisted-workflows-reference.md",
      "max_repo_lines": 40
    },
    {
      "id": "git-strategy",
      "role": "externalized",
      "repo_path": "docs/reference-configs/git-strategy.md",
      "asset_path": "assets/reference-configs/git-strategy.md",
      "brain_path": "brain/repo-harness/references/ai-driven-version-control-strategy.md",
      "max_repo_lines": 40
    },
    {
      "id": "changelog-versioning",
      "role": "externalized",
      "repo_path": "docs/reference-configs/changelog-versioning.md",
      "asset_path": "assets/reference-configs/changelog-versioning.md",
      "brain_path": "brain/repo-harness/references/changelog-versioning-reference.md",
      "max_repo_lines": 40
    },
    {
      "id": "coding-standards",
      "role": "externalized",
      "repo_path": "docs/reference-configs/coding-standards.md",
      "asset_path": "assets/reference-configs/coding-standards.md",
      "brain_path": "brain/repo-harness/references/coding-standards-reference.md",
      "max_repo_lines": 40
    },
    {
      "id": "release-deploy",
      "role": "externalized",
      "repo_path": "docs/reference-configs/release-deploy.md",
      "asset_path": "assets/reference-configs/release-deploy.md",
      "brain_path": "brain/repo-harness/runbooks/runbook-agentic-release-deploy.md",
      "max_repo_lines": 40
    },
    {
      "id": "spa-day-protocol",
      "role": "externalized",
      "repo_path": "docs/reference-configs/spa-day-protocol.md",
      "asset_path": "assets/reference-configs/spa-day-protocol.md",
      "brain_path": "brain/repo-harness/runbooks/runbook-agentic-spa-day-protocol.md",
      "max_repo_lines": 40
    },
    {
      "id": "workflow-orchestration",
      "role": "externalized",
