{
  "version": "1.0.0",
  "contractId": "tasks-first-harness-v1",
  "compatibility": {
    "agents": [
      "claude",
      "codex"
    ],
    "repoLocalFirst": false
  },
  "externalTooling": {
    "waza": {
      "sourceRepo": "tw93/Waza",
      "managedSkills": [
        "think",
        "hunt",
        "check",
        "health"
      ],
      "primaryHost": "codex",
      "codexPrimaryPath": "~/.codex/skills",
      "stagingCachePath": "~/.agents/skills",
      "syncMode": "stage-upstream-then-copy-to-codex",
      "hostDriftPolicy": "report-per-host-version-staging-and-upstream-drift"
    },
    "codexAutomationProfile": {
      "requiredSkills": [
        "health",
        "check",
        "mermaid"
      ],
      "optionalSkills": [],
      "mode": "codex-runtime-reference",
      "source": "~/.codex/skills",
      "routes": {
        "workflowHealth": "waza:health",
        "reviewGate": "waza:check",
        "architectureDiagram": "mermaid"
      },
      "vendoringPolicy": "do-not-vendor-skill-body"
    },
    "diagramDesign": {
      "skillName": "mermaid",
      "primaryHost": "codex",
      "codexPrimaryPath": "~/.codex/skills/mermaid",
      "syncMode": "external-installed-skill",
      "vendoringPolicy": "do-not-vendor"
    }
  },
  "agenticDevelopment": {
    "routing": {
      "productDiscovery": "parent-agent:geju",
      "complexEngineeringPlan": "parent-agent:geju",
      "designPlan": "parent-agent:geju",
      "smallOrMediumPlan": "waza:think",
      "bugOrRegression": "waza:hunt",
      "postImplementationReview": "waza:check"
    },
    "dueDiligence": {
      "levels": [
        "P1_GLOBAL_ARCHITECTURE",
        "P2_DATA_FLOW_TRACE",
        "P3_DESIGN_DECISION"
      ],
      "explicitReportRequiredFor": [
        "complex_engineering_plan",
        "hunt",
        "risky_refactor",
        "deployment",
        "auth_payment_data",
        "shared_contract"
      ]
    }
  },
  "documentation": {
    "referenceConfigs": {
      "source": "user-level-runtime-docs",
      "repoStubDirectory": "docs/reference-configs",
      "packageDirectory": "assets/reference-configs",
      "resolverCommand": "repo-harness docs path <doc-id>",
      "stubMarker": "<!-- repo-harness: reference-config-stub v1 -->"
    }
  },
  "helpers": {
    "runtimeDirectory": "package:assets/templates/helpers",
    "scripts": [
      "new-spec.sh",
      "new-sprint.sh",
      "new-plan.sh",
      "capture-plan.sh",
      "plan-to-todo.sh",
      "contract-run.ts",
      "contract-worktree.sh",
      "acceptance-receipt.ts",
      "merge-gate.ts",
      "ship-worktrees.sh",
      "archive-workflow.sh",
      "refresh-current-status.sh",
      "prepare-handoff.sh",
      "verify-contract.sh",
      "run-bounded-verifier-command.ts",
      "validate-harness-profile-benchmark.ts",
      "summarize-failures.sh",
      "verify-sprint.sh",
      "harness-trace-grade.sh",
      "sprint-backlog.sh",
      "factor-lab-new.sh",
      "factor-lab-promote.sh",
      "factor-lab-reject.sh",
      "factor-lab-check.sh",
      "check-task-sync.sh",
      "check-deploy-sql-order.sh",
      "check-architecture-sync.sh",
      "check-agent-tooling.sh",
      "install-agent-fleet.sh",
      "check-context-files.sh",
      "check-brain-manifest.sh",
      "sync-brain-docs.sh",
      "check-skill-version.ts",
      "select-agent-context-blocks.sh",
      "ensure-task-workflow.sh",
      "check-task-workflow.sh",
      "maintenance-triage.sh",
      "heartbeat-triage.sh",
      "switch-plan.sh",
      "workflow-contract.ts",
      "inspect-project-state.ts",
      "capability-resolver.ts",
      "architecture-event.ts",
      "capability-config.ts",
      "architecture-queue.sh",
      "archive-architecture-request.sh",
      "context-contract-sync.sh",
      "workstream-sync.sh",
      "prepare-codex-handoff.sh",
      "codex-handoff-resume.sh",
      "recovery-view-cli.ts"
    ],
    "descriptions": {
      "new-spec": "Create docs/spec.md from the product spec template",
      "new-sprint": "Create a program-level sprint backlog under plans/sprints/",
      "new-plan": "Create a new execution plan file under plans/",
      "capture-plan": "Capture a finished planning note as a plan artifact or checklist rows",
      "plan-to-todo": "Activate an approved plan and start its contract worktree when enabled",
      "contract-run": "Preflight, dry-run, or run a task contract's delegated worker and verifier",
      "contract-worktree": "Start, finish, clean up, or report status of a contract execution worktree",
      "acceptance-receipt": "Record, project, or verify the single structured semantic acceptance authority",
      "merge-gate": "Create or verify the provider-free SHA-bound local merge seal for an exact merge candidate",
      "ship-worktrees": "Commit, push, and open draft PRs for finished contract worktrees",
      "archive-workflow": "Archive a completed or abandoned plan and its workflow artifacts",
      "refresh-current-status": "Refresh tasks/current.md from repo-local workflow artifacts",
      "prepare-handoff": "Write the current-state handoff snapshot and trigger a resume refresh",
      "verify-contract": "Check a task contract's YAML exit criteria and update its status header",
      "run-bounded-verifier-command": "Run a verifier command under an epoch-ms deadline, capturing log and timed exit result",
      "validate-harness-profile-benchmark": "Validate a harness profile benchmark report and emit its byte-bound evidence hash",
      "summarize-failures": "Summarize recorded workflow failure log entries",
      "verify-sprint": "Verify the active sprint contract's exit criteria and allowed paths",
      "harness-trace-grade": "Grade a harness run trace against pass/fail criteria",
      "sprint-backlog": "Initialize, inspect, and advance a program-level sprint backlog",
      "factor-lab-new": "Create a new factor candidate workspace and register it",
      "factor-lab-promote": "Promote a factor candidate into the committed registry",
      "factor-lab-reject": "Reject a factor candidate and record the reason",
      "factor-lab-check": "Inspect factor registry health and candidate completeness",
      "check-task-sync": "Check that substantive changes are synchronized with tasks/ updates",
      "check-deploy-sql-order": "Validate deploy SQL filenames follow the configured ordering policy",
      "check-architecture-sync": "Gate pending architecture drift for capabilities touched by this change",
      "check-agent-tooling": "Check the installed agent fleet copy is current with the packaged source",
      "install-agent-fleet": "Install or sync the packaged agent fleet into the target host",
      "check-context-files": "Scan AGENTS.md and CLAUDE.md files for risky embedded instructions",
      "check-brain-manifest": "Validate the external knowledge manifest and referenced vault files",
      "sync-brain-docs": "Sync opted-in repo docs to the local brain file vault",
      "check-skill-version": "Check repo-harness version consistency and project migration status",
      "select-agent-context-blocks": "List capability-prefix directories to load as agent context blocks",
      "ensure-task-workflow": "Ensure task workflow scaffolding and templates exist, optionally start a plan",
      "check-task-workflow": "Check workflow contract and policy compliance for the current repo",
      "maintenance-triage": "Scan tasks/lessons.md for recurring themes needing guard, eval, or skill action",
      "heartbeat-triage": "Run a scheduled heartbeat check and record findings to the triage inbox",
      "switch-plan": "Switch or list the active plan marker for this worktree",
      "workflow-contract": "Load and print the resolved workflow contract as JSON",
      "inspect-project-state": "Detect legacy contract drift and produce an initialize, migrate, audit, or repair plan",
      "capability-resolver": "List, match, validate, or export capability registry entries",
      "architecture-event": "Low-level JSON helpers for architecture request event bookkeeping",
      "capability-config": "Register a new capability prefix and sync its contract files",
      "architecture-queue": "Record, index, gate, and triage pending architecture drift requests",
      "archive-architecture-request": "Archive a handled architecture drift request without deciding scope",
      "context-contract-sync": "Sync the latest or a given architecture event into local CLAUDE.md/AGENTS.md blocks",
      "workstream-sync": "Ensure a durable capability workstream ledger exists for a plan slice",
      "prepare-codex-handoff": "Refresh the handoff snapshot, resume packet, and global Codex handoff pointer",
      "codex-handoff-resume": "Rebuild the repo's resume packet, optionally printing the resume prompt",
      "recovery-view-cli": "Materialize the handoff/resume recovery views (and optionally the Codex-global packet) from the last-published checkpoint plus live workflow context"
    },
    "dir": "package:assets/templates/helpers",
    "runtimeSource": "package"
  },
