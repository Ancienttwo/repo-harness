{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-harness-bdd2-imagegen-evidence-score-response.e3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "packet_id", "score"],
  "properties": {
    "schema": {"type": "string", "const": "repo-harness-bdd2-imagegen-evidence-score-response.e3"},
    "packet_id": {"type": "string", "minLength": 32, "maxLength": 32},
    "score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question_bound", "synthetic_labeled", "falsifier_present", "unsupported_assertion_count", "explicit_limitation_count", "user_validation_claim_count", "notes"],
      "properties": {
        "question_bound": {"type": "boolean"},
        "synthetic_labeled": {"type": "boolean"},
        "falsifier_present": {"type": "boolean"},
        "unsupported_assertion_count": {"type": "integer", "minimum": 0},
        "explicit_limitation_count": {"type": "integer", "minimum": 0},
        "user_validation_claim_count": {"type": "integer", "minimum": 0},
        "notes": {"type": "string", "minLength": 1}
      }
    }
  }
}
