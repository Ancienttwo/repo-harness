{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-harness-bdd2-browser-evidence-score-response.e3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "packet_id", "score"],
  "properties": {
    "schema": {"const": "repo-harness-bdd2-browser-evidence-score-response.e3"},
    "packet_id": {"type": "string", "minLength": 32, "maxLength": 32},
    "score": {
      "type": "object",
