      "required": ["provenance_complete", "question_bound", "privacy_reviewed", "adopt_adapt_avoid_complete", "unsupported_assertion_count", "explicit_limitation_count", "feature_need_inference_count", "notes"],
      "properties": {
        "provenance_complete": {"type": "boolean"},
        "question_bound": {"type": "boolean"},
        "privacy_reviewed": {"type": "boolean"},
        "adopt_adapt_avoid_complete": {"type": "boolean"},
        "unsupported_assertion_count": {"type": "integer", "minimum": 0},
        "explicit_limitation_count": {"type": "integer", "minimum": 0},
        "feature_need_inference_count": {"type": "integer", "minimum": 0},
        "notes": {"type": "string", "minLength": 1}
      }
    }
  }
}
