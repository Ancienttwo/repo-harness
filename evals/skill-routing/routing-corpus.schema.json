{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://repo-harness.dev/schemas/skill-routing-corpus.schema.json",
  "title": "repo-harness skill-routing corpus",
  "description": "Bilingual routing corpus for the SSD skill-surface discovery convergence work-package (SSD-01 frozen baseline). Validated by scripts/run-skill-routing-eval.ts and tests/skill-routing-eval.test.ts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "cases"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/case"
      }
    }
  },
  "definitions": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "lang",
        "kind",
        "prompt",
        "expected_route"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique kebab-case case identifier.",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "lang": {
          "type": "string",
          "enum": [
            "zh",
            "en"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "positive",
            "ambiguous",
            "quoted-name",
            "negated",
            "hypothetical",
            "status-only",
            "ordinary-qa"
          ]
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "expected_route": {
          "type": "string",
          "description": "One of the 10 target canonical package names, or \"none\" when no workflow should be invoked.",
          "enum": [
            "repo-harness",
            "repo-harness-setup",
            "repo-harness-plan",
            "repo-harness-product",
            "repo-harness-check",
            "repo-harness-ship",
            "repo-harness-architecture",
            "repo-harness-cross-review",
            "merge-gate",
            "repo-harness-chatgpt",
            "none"
          ]
        },
        "overlap_terms": {
          "type": "array",
          "description": "Optional literal overlap-vocabulary terms this case exercises (e.g. \"check\", \"review\").",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string",
          "description": "Optional free-text clarification for a non-obvious disambiguation."
        }
      }
    }
  }
}
